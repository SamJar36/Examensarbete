@page "/highscores"
@rendermode InteractiveServer
@inject IHttpClientFactory ClientFactory
@using Examensarbete.Blazor.Shared.Responses;

<PageTitle>Highscores</PageTitle>

<div class="page-wrapper">

    <!-- TITLE FRAME -->
    <section class="content-section">

        <div class="pixel-frame">
            <span class="frame-corner top-left"></span>
            <span class="frame-corner top-right"></span>
            <span class="frame-corner bottom-left"></span>
            <span class="frame-corner bottom-right"></span>

            <span class="frame-edge top"></span>
            <span class="frame-edge bottom"></span>
            <span class="frame-edge left"></span>
            <span class="frame-edge right"></span>

            <div class="box-inner">

                <div class="hero-text title-highlight">
                    HIGHSCORES
                </div>

            </div>
        </div>

    </section>

    <!-- SCORES FRAME -->
    <section class="content-section">

        <div class="pixel-frame">
            <span class="frame-corner top-left"></span>
            <span class="frame-corner top-right"></span>
            <span class="frame-corner bottom-left"></span>
            <span class="frame-corner bottom-right"></span>

            <span class="frame-edge top"></span>
            <span class="frame-edge bottom"></span>
            <span class="frame-edge left"></span>
            <span class="frame-edge right"></span>

            <div class="box-inner">

                <div class="highscore-list">

                    @for (int i = 0; i < _highScores.Count; i++)
                    {
                        var score = _highScores[i];

                        <div class="highscore-row">
                            <div class="score-name">
                                @(score.Name?.ToUpper() ?? "")
                            </div>

                            <div class="score-value">
                                @score.Score
                            </div>
                        </div>

                        @if (i < _highScores.Count - 1)
                        {
                            <div class="highscore-divider"></div>
                        }
                    }

                </div>

            </div>
        </div>

    </section>

</div>


@code {
    private List<ScoreResponse> _highScores = new List<ScoreResponse>();
    protected override async Task OnInitializedAsync()
    {
        for (int i = 0; i < 14; i++) {
            _highScores.Add(new ScoreResponse
            {
                Name = "",
                Score = 0,
            });
        }

        try 
        {
            HttpClient? client = ClientFactory.CreateClient(name: "ApiGateway");
            Console.WriteLine("Blazor: Fetching high scores from API Gateway...");
            List<ScoreResponse>? response = await client.GetFromJsonAsync<List<ScoreResponse>>(requestUri: "api/highscore");
            Console.WriteLine($"Blazor: Received high scores from API Gateway... {response?.Count ?? 0} entries found.");
            if (response is not null)
            {
                try 
                {
                    _highScores.Clear();
                    foreach (ScoreResponse score in response)
                    {
                        _highScores.Add(score);
                    };
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Blazor: Error occurred while clearing local list and adding highscore: {ex.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Blazor: Error occurred while fetching high scores: {ex.Message}");
        }
    }
}
